# ==============================================================================
# Imtihan Portal Environment Configuration
# ==============================================================================

# Django Core Settings
DEBUG=True
SECRET_KEY=change_this_in_production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Connection
DB_ENGINE=postgresql
DB_NAME=imtihan_db
DB_USER=imtihan_user
DB_PASSWORD=change_this_in_production
DB_HOST=127.0.0.1
DB_PORT=5432

# AI Model Credentials
# Get a FREE Gemini API key from: https://aistudio.google.com/
# 1. Sign in with Google
# 2. Click "Get API Key"
# 3. Create a new key
# 4. Paste it below
# Free tier: 15 req/min, 1M tokens/day — more than enough for 5 questions/user/day
GEMINI_API_KEY=get_from_google_ai_studio

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# Quick Post (admin mobile posting)
QUICK_POST_SECRET=change_this_in_production
